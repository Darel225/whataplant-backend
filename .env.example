# ============================================================
# WhatAPlant Backend — Variables d'environnement
# Renomme ce fichier en .env et remplis tes vraies valeurs
# ============================================================

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ton_mot_de_passe
DB_NAME=whataplant

# API PlantNet
PLANTNET_API_KEY=ta_cle_plantnet_ici

# API Grok (xAI) — obtenir sur https://console.x.ai/
GROK_API_KEY=votre_cle_ici

# Stockage local des images de scan
# En production Render, les fichiers du disque peuvent disparaître après redéploiement.
# Pour garder les anciennes images, il faut un stockage persistant ou externe.

# Cloudinary (recommandé pour la prod)
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=ton_api_key
CLOUDINARY_API_SECRET=ton_api_secret
# Optionnel: dossier Cloudinary où ranger les scans
CLOUDINARY_FOLDER=whataplant/scans